# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate a random 32+ char secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ─── Cloudinary ─────────────────────────────────────────────────────────────
# Get these from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Green API (WhatsApp) ────────────────────────────────────────────────────
# Get these from: https://green-api.com → Dashboard
GREEN_API_INSTANCE_ID=your-instance-id
GREEN_API_TOKEN=your-api-token

# ─── Vercel Cron Security ────────────────────────────────────────────────────
# Add this in Vercel dashboard under Environment Variables
CRON_SECRET=your-cron-secret-key

# ─── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
